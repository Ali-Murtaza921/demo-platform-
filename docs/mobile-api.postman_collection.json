{
  "info": {
    "name": "Demos Platform Mobile API",
    "description": "Mobile-friendly Postman collection for Sanctum auth, onboarding, public content, and the current DEMOS API surface. Participation endpoints now require full constituent verification (email + location + identity/legacy verified status) and suspended accounts are blocked from login and engagement actions.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ],
              "query": []
            },
            "description": "Create a user and trigger a 6-digit email verification code for the mobile onboarding flow.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"{{mobile_full_name}}\",\n  \"email\": \"{{mobile_email}}\",\n  \"phone_number\": \"{{mobile_phone_number}}\",\n  \"password\": \"{{mobile_password}}\",\n  \"password_confirmation\": \"{{mobile_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.unset(\"auth_token\");"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify Email Code",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/verify-email-code",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "verify-email-code"
              ],
              "query": []
            },
            "description": "Submit the emailed 6-digit code and save the returned bearer token. Suspended accounts are blocked even after a valid code.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{mobile_email}}\",\n  \"code\": \"{{verification_code}}\",\n  \"device_name\": \"{{device_name}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) { pm.collectionVariables.set(\"auth_token\", data.token); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Resend Verification Code",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/resend-verification-code",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "resend-verification-code"
              ],
              "query": []
            },
            "description": "Request a fresh verification code after the resend cooldown expires.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{mobile_email}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
